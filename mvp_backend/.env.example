SECRET_KEY=local-dev-secret
DATABASE_URL=sqlite:///./mvp.db
BOOTSTRAP_ADMIN=admin:admin123
ENV=development
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7
LOGIN_RATE_LIMIT=10/minute
