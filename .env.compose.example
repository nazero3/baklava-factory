# Copy to .env in the repo root, then fill in real values before deploying.
# NEVER commit a .env file with real secrets.

POSTGRES_USER=manbaj
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_DB=manbaj

# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-strong-secret-key

# Creates the first admin on first boot: username:password
BOOTSTRAP_ADMIN=admin:change-me-admin-password
